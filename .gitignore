# Cloudflare Workers
.wrangler/
worker/.wrangler/

# Node
node_modules/
worker/node_modules/

# Root-level npm scaffolding (wrangler lives in worker/ — this is redundant)
/package.json
/package-lock.json

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Secrets (belt-and-braces — secrets should live in Cloudflare via `wrangler secret put`, never in the repo)
.env
.env.*
.dev.vars
worker/.dev.vars
*.uetbak
*.serif-bak
*.pre-301-bak
*.bak

# Claude Code internal tooling — never commit
.claude/
node_modules/

# Block unsolicited agent skill bundles — see incident 2026-05-16 (higgsfield)
.agents/
skills-lock.json

# Git internal file that should NEVER be in the working tree
FETCH_HEAD

# Worker timestamped backups (e.g. admin.ts.bak.20260512T173749)
*.bak.*
